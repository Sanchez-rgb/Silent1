# HealingSpace 环境变量配置模板
# 请复制此文件为 .env.local 并填入实际的值

# DeepSeek API 配置
# 用于 AI 对话功能
VITE_DEEPSEEK_API_KEY=your-deepseek-api-key-here
VITE_DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# 微信支付配置（需要企业资质）
# 用于陪聊服务支付功能
REACT_APP_WECHAT_APP_ID=your-wechat-app-id
REACT_APP_WECHAT_MCH_ID=your-merchant-id
REACT_APP_WECHAT_API_KEY=your-wechat-pay-api-key

# 数据库配置（如果使用云数据库）
# 当前使用 IndexedDB 本地存储，如需云端同步可配置
REACT_APP_DATABASE_URL=your-database-url
REACT_APP_DATABASE_KEY=your-database-key

# WebSocket 服务配置
# 用于匿名聊天室功能
REACT_APP_WS_URL=wss://your-server.com/ws

# 平台配置
# 陪聊服务佣金比例
REACT_APP_PLATFORM_FEE_RATE=0.15

# 陪聊价格配置（元/分钟）
REACT_APP_NORMAL_COMPANION_PRICE=1.5
REACT_APP_PROFESSIONAL_COMPANION_PRICE=3.0